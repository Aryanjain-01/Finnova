# PostgreSQL — use a normal postgresql:// URL (not prisma+postgres:// unless you run `npx prisma dev`).
#
# Local Docker (see docker-compose.yml in this repo):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_tracker"
#
# Hosted (Neon, Supabase, Railway):
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# NextAuth / Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-string"
AUTH_TRUST_HOST="true"

# Optional: public URL in production
# NEXTAUTH_URL="http://localhost:3000"
